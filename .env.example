# Final public origin used for canonical URLs, Open Graph and the XML sitemap.
NEXT_PUBLIC_SITE_URL=https://www.libidiamonds.co.il

# Enable indexing only for the canonical domain build. Keep false for vee-app staging routes.
NEXT_PUBLIC_ALLOW_INDEXING=false

# Paste only the verification token from Google Search Console, not the full meta tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

{
  "name": "libi-diamonds-2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "homepage:signatures": "node scripts/homepage/process-signatures.mjs",
    "images:prepare": "python scripts/product-images/prepare_masters.py",
    "images:render": "node scripts/product-images/render.mjs",
    "images:validate": "node scripts/product-images/validate.mjs --strict",
    "images:contact-sheet": "node scripts/product-images/contact-sheet.mjs",
    "images:check": "npm run images:render && npm run images:validate && npm run images:contact-sheet",
    "try-on:assets": "node scripts/try-on/prepare-assets.mjs",
    "try-on:validate": "node scripts/try-on/validate-assets.mjs",
    "try-on:contact-sheet": "node scripts/try-on/contact-sheet.mjs",
    "try-on:check": "npm run try-on:assets && npm run try-on:validate && npm run try-on:contact-sheet",
    "try-on:v3:assets": "node scripts/try-on/prepare-v3-assets.mjs",
    "try-on:v3:validate": "node scripts/try-on/validate-v3-assets.mjs",
    "try-on:v3:contact-sheet": "node scripts/try-on/contact-sheet-v3.mjs",
    "try-on:v3:geometry": "node scripts/try-on/test-geometry-v3.mjs",
    "try-on:v3:check": "npm run try-on:v3:assets && npm run try-on:v3:validate && npm run try-on:v3:contact-sheet && npm run try-on:v3:geometry",
    "try-on:bracelets:assets": "node scripts/try-on/prepare-bracelet-assets.mjs",
    "try-on:bracelets:validate": "node scripts/try-on/validate-bracelet-assets.mjs",
    "try-on:bracelets:contact-sheet": "node scripts/try-on/contact-sheet-bracelets.mjs",
    "try-on:bracelets:geometry": "node scripts/try-on/test-bracelet-geometry.mjs",
    "try-on:bracelets:check": "npm run try-on:bracelets:assets && npm run try-on:bracelets:validate && npm run try-on:bracelets:contact-sheet && npm run try-on:bracelets:geometry",
    "try-on:earrings:assets": "node scripts/try-on/prepare-earring-assets.mjs",
    "try-on:earrings:validate": "node scripts/try-on/validate-earring-assets.mjs",
    "try-on:earrings:contact-sheet": "node scripts/try-on/contact-sheet-earrings.mjs",
    "try-on:earrings:geometry": "node scripts/try-on/test-earring-geometry.mjs",
    "try-on:earrings:check": "npm run try-on:earrings:assets && npm run try-on:earrings:validate && npm run try-on:earrings:contact-sheet && npm run try-on:earrings:geometry",
    "spin:validate": "node scripts/product-spin/validate.mjs",
    "spin:contact-sheet": "node scripts/product-spin/contact-sheet.mjs",
    "spin:check": "npm run spin:validate && npm run spin:contact-sheet",
    "catalog:validate": "node scripts/catalog/validate-expansion.mjs",
    "catalog:validate:images": "node scripts/catalog/validate-expansion.mjs --images"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5"
  }
}
